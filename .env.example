# Core server
SENTINEL_HOST=127.0.0.1
SENTINEL_PORT=8787

# AI provider: offline | ollama | huggingface
SENTINEL_AI_PROVIDER=offline

# Ollama config (local free inference)
SENTINEL_OLLAMA_URL=http://127.0.0.1:11434
SENTINEL_OLLAMA_MODEL=llama3.1:8b

# Hugging Face config (online free-tier capable)
SENTINEL_HF_MODEL=mistralai/Mistral-7B-Instruct-v0.2
HF_API_TOKEN=

